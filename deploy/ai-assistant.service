# ============================================================================
# LEGACY DEPLOYMENT PATH WARNING
# This systemd unit represents a legacy deployment path kept for reference.
# Corporate AI Assistant v1.1 primary/supported deployment path is:
# Linux VM + Docker Compose + install.sh
# This unit is not the primary validated release baseline for v1.1.
# ============================================================================
[Unit]
Description=Corporate AI Assistant
After=network-online.target ollama.service
Requires=ollama.service
[Service]
Type=simple
User=aiassistant
Group=aiassistant
WorkingDirectory=/opt/corporate-ai-assistant
Environment="PATH=/opt/corporate-ai-assistant/.venv/bin"
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/corporate-ai-assistant/.venv/bin/python /opt/corporate-ai-assistant/app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/corporate-ai-assistant

[Install]
WantedBy=multi-user.target
