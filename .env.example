# Example environment file for ai_agent_v1.1
# Replace all example values before deployment.

# Active Directory Settings
LDAP_SERVER=ldap://dc01.example.local
LDAP_DOMAIN=example.local
LDAP_BASE_DN=dc=example,dc=local
LDAP_NETBIOS_DOMAIN=EXAMPLE

# Kerberos Settings
KERBEROS_REALM=EXAMPLE.LOCAL
KERBEROS_KDC=dc01.example.local
AD_SERVER_IP_OVERRIDE=
INSTALL_TEST_USER=

# JWT / Cookies
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TRUSTED_AUTH_PROXY_ENABLED=false
SSO_ENABLED=false
SSO_LOGIN_PATH=/auth/sso/login
SSO_SERVICE_PRINCIPAL=
SSO_KEYTAB_PATH=/etc/corporate-ai-sso/http.keytab
MODEL_POLICY_DIR=model_policies
MODEL_ACCESS_CODING_GROUPS=
MODEL_ACCESS_ADMIN_GROUPS=
COOKIE_DOMAIN=

# Ollama Settings
OLLAMA_URL=http://ollama:11434/api/chat
DEFAULT_MODEL=phi3:mini
AUTO_START_OLLAMA=false
GPU_ENABLED=false
ENABLE_PARSER_STAGE=true
ENABLE_PARSER_PUBLIC_CUTOVER=true

# Redis / Limits
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me
PERSISTENT_DB_ENABLED=false
PERSISTENT_DB_URL=postgresql+psycopg://app_user:change-me@postgres:5432/corporate_ai
PERSISTENT_DB_ECHO=false
PERSISTENT_DB_POOL_PRE_PING=true
PERSISTENT_DB_BOOTSTRAP_SCHEMA=false
PERSISTENT_DB_SHADOW_COMPARE=false
PERSISTENT_DB_READ_THREADS=false
PERSISTENT_DB_READ_MESSAGES=false
PERSISTENT_DB_DUAL_WRITE_CONVERSATION=false
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
DEBUG_LOAD_ENABLED=false
LOG_LEVEL=INFO
