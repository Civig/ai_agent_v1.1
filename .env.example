# Example environment file for ai_agent_v1.1
# Replace all example values before deployment.

# Install / auth profile
# enterprise is the default validated baseline.
# standalone_gpu_lab is for isolated GPU validation only and must never be Internet-exposed as production.
INSTALL_PROFILE=enterprise
AUTH_MODE=ad
# lab_open requires explicit operator acknowledgment and fails fast when the ack is missing.
LAB_OPEN_AUTH_ACK=false
LAB_USER_USERNAME=lab_user
LAB_USER_CANONICAL_PRINCIPAL=lab_user@LOCAL.LAB

# Active Directory Settings
LDAP_SERVER=ldap://dc01.example.local
LDAP_GSSAPI_SERVICE_HOST=dc01
LDAP_DOMAIN=example.local
LDAP_BASE_DN=dc=example,dc=local
LDAP_NETBIOS_DOMAIN=EXAMPLE

# Kerberos Settings
KERBEROS_REALM=EXAMPLE.LOCAL
KERBEROS_KDC=dc01.example.local
AD_SERVER_IP_OVERRIDE=
INSTALL_TEST_USER=

# JWT / Cookies
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TRUSTED_AUTH_PROXY_ENABLED=false
SSO_ENABLED=false
# Uvicorn trusts forwarded headers only from this allowlist.
# Leave blank to trust only loopback plus the local app-container networks;
# in production set the exact reverse-proxy source IP/CIDR explicitly.
FORWARDED_ALLOW_IPS=
# Reserved proxy-auth headers are accepted only from trusted reverse-proxy source addresses.
TRUSTED_PROXY_SOURCE_CIDRS=127.0.0.1/32,::1/128
SSO_LOGIN_PATH=/auth/sso/login
SSO_SERVICE_PRINCIPAL=
SSO_KEYTAB_PATH=/etc/corporate-ai-sso/http.keytab
# Optional break-glass admin for dashboard-only access.
# Disabled by default; store only a password hash in .env.
# Installer-managed .env uses compose-safe escaping for LOCAL_ADMIN_PASSWORD_HASH
# so the runtime still receives the logical single-$ hash form.
# If the installer generates a one-time bootstrap secret, plaintext is shown once
# and stored only in a root-only host file outside .env until password rotation.
LOCAL_ADMIN_ENABLED=false
LOCAL_ADMIN_USERNAME=admin_ai
LOCAL_ADMIN_PASSWORD_HASH=
LOCAL_ADMIN_FORCE_ROTATE=false
LOCAL_ADMIN_BOOTSTRAP_REQUIRED=false
MODEL_POLICY_DIR=model_policies
MODEL_ACCESS_CODING_GROUPS=
MODEL_ACCESS_ADMIN_GROUPS=
# Read-only dashboard access allowlist. CSV usernames, normalized like login usernames.
# Leave empty to keep the dashboard closed for everyone.
ADMIN_DASHBOARD_USERS=
COOKIE_DOMAIN=

# Ollama Settings
REDIS_IMAGE=redis@sha256:8b81dd37ff027bec4e516d41acfbe9fe2460070dc6d4a4570a2ac5b9d59df065
POSTGRES_IMAGE=postgres@sha256:2586e2a95d1c9b31cb2967feb562948f7d364854453d703039b6efa45fe48417
OLLAMA_IMAGE=ollama/ollama@sha256:5a5d014aa774f78ebe1340c0d4afc2e35afc12a2c3b34c84e71f78ea20af4ba3
NGINX_IMAGE=nginx@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
OLLAMA_URL=http://ollama:11434/api/chat
DEFAULT_MODEL=phi3:mini
# Bounded timeout for each `ollama pull` bootstrap attempt in seconds.
OLLAMA_PULL_TIMEOUT_SECONDS=900
AUTO_START_OLLAMA=false
GPU_ENABLED=false
ENABLE_PARSER_STAGE=true
ENABLE_PARSER_PUBLIC_CUTOVER=true

# Redis / Limits
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me
POSTGRES_DB=corporate_ai
POSTGRES_USER=corporate_ai
POSTGRES_PASSWORD=change-me
PERSISTENT_DB_ENABLED=true
PERSISTENT_DB_URL=postgresql+psycopg://corporate_ai:change-me@postgres:5432/corporate_ai
PERSISTENT_DB_ECHO=false
PERSISTENT_DB_POOL_PRE_PING=true
PERSISTENT_DB_BOOTSTRAP_SCHEMA=true
PERSISTENT_DB_SHADOW_COMPARE=false
PERSISTENT_DB_READ_THREADS=true
PERSISTENT_DB_READ_MESSAGES=true
PERSISTENT_DB_DUAL_WRITE_CONVERSATION=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
DEBUG_LOAD_ENABLED=false
LOG_LEVEL=INFO
